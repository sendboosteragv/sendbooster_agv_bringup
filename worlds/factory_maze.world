    <model name="zd_p07"><static>true</static><pose>67 -40 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual></link></model>
    <model name="zd_p08"><static>true</static><pose>82 -40 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual></link></model>
    <model name="zd_p09"><static>true</static><pose>97 -40 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual></link></model>
    <model name="zd_p10"><static>true</static><pose>112 -40 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual></link></model>
    <model name="zd_p11"><static>true</static><pose>127 -40 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
