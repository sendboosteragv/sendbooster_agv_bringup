    <model name="zd_p12"><static>true</static><pose>60 -60 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry><material><ambient>0.5 0.5 0.5 1</ambient></material></visual></link></model>
    <model name="zd_p13"><static>true</static><pose>75 -60 1.25 0 0 0</pose>
      <link name="l"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>2.5</length></cylinder></geometry></collision>
