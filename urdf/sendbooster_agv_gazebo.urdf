<?xml version="1.0"?>
<!--
  Gazebo simulation URDF for Sendbooster AGV
  Based on sendbooster_agv.urdf with added:
  - Inertial properties for physics simulation
  - Caster wheels for stability
  - Gazebo diff_drive plugin (replaces motor_driver_node)
  - Gazebo ray sensors x2 (replaces rplidar_ros)
  - Gazebo IMU sensor (replaces stella_ahrs)
-->
<robot name="sendbooster_agv">

  <!-- ====== Materials ====== -->
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="dark"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="light_black"><color rgba="0.4 0.4 0.4 1.0"/></material>

  <!-- ====== Base Footprint (ground projection) ====== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ====== Base Link (robot body: 0.6m x 0.6m x 0.3m) ====== -->
  <!-- Collision box raised so bottom is above ground (z=0.01), preventing
       the body from resting on the floor instead of the wheels. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry><box size="0.6 0.6 0.28"/></geometry>
      <material name="light_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry><box size="0.6 0.6 0.28"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <mass value="20.0"/>
      <inertia ixx="0.75" ixy="0" ixz="0" iyy="0.75" iyz="0" izz="1.2"/>
    </inertial>
  </link>

  <!-- ====== Left Wheel ====== -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <!-- y=0.185 (half of wheel_separation 0.37m), z=0.0965 (wheel_radius, touches ground) -->
    <!-- Both wheels use rpy=-1.5708: axes point +Y so positive velocity = forward -->
    <origin xyz="0 0.185 0.0965" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <geometry><cylinder radius="0.0965" length="0.048"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0965" length="0.048"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.0025" ixy="0" ixz="0" iyy="0.0025" iyz="0" izz="0.0047"/>
    </inertial>
  </link>

  <!-- ====== Right Wheel ====== -->
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0 -0.185 0.0965" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <geometry><cylinder radius="0.0965" length="0.048"/></geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0965" length="0.048"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.0025" ixy="0" ixz="0" iyy="0.0025" iyz="0" izz="0.0047"/>
    </inertial>
  </link>

  <!-- ====== Front Caster ====== -->
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster_link"/>
    <origin xyz="0.25 0 0.015" rpy="0 0 0"/>
  </joint>

  <link name="front_caster_link">
    <visual>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000009" ixy="0" ixz="0" iyy="0.000009" iyz="0" izz="0.000009"/>
    </inertial>
  </link>

  <!-- ====== Back Caster ====== -->
  <joint name="back_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_caster_link"/>
    <origin xyz="-0.25 0 0.015" rpy="0 0 0"/>
  </joint>

  <link name="back_caster_link">
    <visual>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000009" ixy="0" ixz="0" iyy="0.000009" iyz="0" izz="0.000009"/>
    </inertial>
  </link>

  <!-- ====== IMU Link ====== -->
  <!-- Mounted 180° rotated around Z (same as real robot) -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 3.14159"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <!-- ====== Front LiDAR ====== -->
  <!-- Hardware 0° faces -X, rotated 180° so scan aligns with +X (forward) -->
  <!-- Mounted at z=0.15 above base_link (top of robot body) -->
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="0.32 0 0.32" rpy="0 0 3.14159"/>
  </joint>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0508" length="0.055"/></geometry>
      <material name="dark"/>
    </visual>
    <!-- No collision: ray sensor doesn't need it, and cylinder at z=0 collides with ground -->
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- ====== Back LiDAR ====== -->
  <!-- Mounted at z=0.15 above base_link (top of robot body) -->
  <joint name="lidar_joint_back" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan_back"/>
    <origin xyz="-0.32 0 0.15" rpy="0 0 3.14159"/>
  </joint>

  <link name="base_scan_back">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0508" length="0.055"/></geometry>
      <material name="dark"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- =================== GAZEBO PLUGINS ========================= -->
  <!-- ============================================================ -->

  <!-- Gazebo colors -->
  <gazebo reference="base_link"><material>Gazebo/DarkGrey</material></gazebo>
  <gazebo reference="wheel_left_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="wheel_right_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="front_caster_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="back_caster_link"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="base_scan"><material>Gazebo/FlatBlack</material></gazebo>
  <gazebo reference="base_scan_back"><material>Gazebo/FlatBlack</material></gazebo>

  <!-- Caster friction: near-zero for frictionless sliding -->
  <gazebo reference="front_caster_link">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>
  <gazebo reference="back_caster_link">
    <mu1>0.001</mu1>
    <mu2>0.001</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <!-- Drive wheel friction -->
  <gazebo reference="wheel_left_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
  </gazebo>
  <gazebo reference="wheel_right_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>500000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <!-- ── Differential Drive (replaces motor_driver_node) ── -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>odom:=odom</remapping>
      </ros>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.37</wheel_separation>
      <wheel_diameter>0.193</wheel_diameter>
      <max_wheel_torque>50</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <!-- EKF publishes odom→base_footprint TF, not diff_drive -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <update_rate>50</update_rate>
      <odometry_source>1</odometry_source>  <!-- 1=encoder -->
      <!-- Realistic encoder noise (wheel slip, gear backlash) -->
      <odometry_covariance_diagonal>0.001 0.001 0.001 0.001 0.001 0.01</odometry_covariance_diagonal>
    </plugin>
  </gazebo>

  <!-- ── Front LiDAR (replaces rplidar_ros front) ── -->
  <!-- RPLIDAR A2M8: front 180° only, 12m range, ~10Hz -->
  <gazebo reference="base_scan">
    <sensor type="ray" name="front_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>180</samples>
            <resolution>1</resolution>
            <min_angle>-1.5708</min_angle>
            <max_angle>1.5708</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.30</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.03</stddev>
        </noise>
      </ray>
      <plugin name="front_lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan_raw_front</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ── Back LiDAR (replaces rplidar_ros back) ── -->
  <gazebo reference="base_scan_back">
    <sensor type="ray" name="back_lidar">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>false</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.30</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.03</stddev>
        </noise>
      </ray>
      <plugin name="back_lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan_raw_back</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan_back</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ── IMU Sensor (replaces stella_ahrs) ── -->
  <gazebo reference="imu_link">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <frame_name>imu_link</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

</robot>
